# =============================================================================
# OCI DocGen — .gitignore
# =============================================================================


# =============================================================================
# Python Virtual Environments
# =============================================================================
venv/
.venv/
env/
ENV/
.env/
.python-version


# =============================================================================
# Python Bytecode and Cache
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo

# Test and coverage tool cache directories
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# Distribution and packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/


# =============================================================================
# Application Runtime Generated Files
# =============================================================================

# .docx documents generated by doc_generator.py
backend/generated_docs/

# Application and Celery log files
*.log
celerybeat-schedule
celerybeat.pid


# =============================================================================
# Credentials and Sensitive Configuration
# =============================================================================

# NEVER commit files containing credentials, tokens, or API keys.
.env
.env.*
*.env
!.env.example

# OCI SDK configuration files (contain private key and fingerprint).
# If you keep .oci/ inside the project, add it here.
.oci/config
.oci/


# =============================================================================
# Frontend Dependencies
# =============================================================================
node_modules/
.npm/
.yarn/
yarn-error.log
package-lock.json
yarn.lock


# =============================================================================
# Local Databases and Persistence
# =============================================================================

# SQLite database generated at runtime by auth.py.
oci_docgen.db

# Redis persistence files generated during local development.
dump.rdb
appendonly.aof
redis.log


# =============================================================================
# Code Editors and IDEs
# =============================================================================

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*


# =============================================================================
# Operating Systems
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# =============================================================================
# Build Tools and CI/CD
# =============================================================================
.tox/
.nox/
.cache/
*.mo
*.pot

# mypy (static type checking) reports and artifacts
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff (linter) artifacts
.ruff_cache/


# =============================================================================
# Jupyter Notebooks (if used for analysis/development)
# =============================================================================
.ipynb_checkpoints
*.ipynb


# =============================================================================
# Temporary Files and Test Uploads
# =============================================================================
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej

# Test images that may have been uploaded during development
test_uploads/
uploads/