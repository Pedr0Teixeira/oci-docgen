# =============================================================================
# OCI DocGen — .gitignore
# =============================================================================


# =============================================================================
# PT-BR: Ambientes Virtuais Python
# EN: Python Virtual Environments
# =============================================================================
venv/
.venv/
env/
ENV/
.env/
.python-version


# =============================================================================
# PT-BR: Bytecode e Cache do Python
# EN: Python Bytecode and Cache
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.pyd
*.pyo

# PT-BR: Diretórios de cache de ferramentas de teste e cobertura
# EN: Test and coverage tool cache directories
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover

# PT-BR: Distribuição e empacotamento
# EN: Distribution and packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST
.eggs/


# =============================================================================
# PT-BR: Arquivos Gerados pela Aplicação em Runtime
# EN: Application Runtime Generated Files
# =============================================================================

# PT-BR: Documentos .docx gerados pelo doc_generator.py
# EN: .docx documents generated by doc_generator.py
backend/generated_docs/

# PT-BR: Arquivos de log da aplicação e do Celery
# EN: Application and Celery log files
*.log
celerybeat-schedule
celerybeat.pid


# =============================================================================
# PT-BR: Credenciais e Configurações Sensíveis
# EN: Credentials and Sensitive Configuration
# =============================================================================

# PT-BR: NUNCA commite arquivos com credenciais, tokens ou chaves de API.
# EN: NEVER commit files containing credentials, tokens, or API keys.
.env
.env.*
*.env
!.env.example

# PT-BR: Arquivos de configuração da OCI SDK (contém chave privada e fingerprint).
#        Se você mantém .oci/ dentro do projeto, adicione aqui.
# EN: OCI SDK configuration files (contain private key and fingerprint).
#     If you keep .oci/ inside the project, add it here.
.oci/config
.oci/


# =============================================================================
# PT-BR: Dependências de Frontend
# EN: Frontend Dependencies
# =============================================================================
node_modules/
.npm/
.yarn/
yarn-error.log
package-lock.json
yarn.lock


# =============================================================================
# PT-BR: Bancos de Dados e Persistência Local
# EN: Local Databases and Persistence
# =============================================================================

# PT-BR: Arquivos de persistência do Redis gerados em desenvolvimento local.
# EN: Redis persistence files generated during local development.
dump.rdb
appendonly.aof
redis.log


# =============================================================================
# PT-BR: Editores de Código e IDEs
# EN: Code Editors and IDEs
# =============================================================================

# Visual Studio Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, WebStorm, IntelliJ)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
\#*\#
.\#*


# =============================================================================
# PT-BR: Sistemas Operacionais
# EN: Operating Systems
# =============================================================================

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# =============================================================================
# PT-BR: Ferramentas de Build e CI/CD
# EN: Build Tools and CI/CD
# =============================================================================
.tox/
.nox/
.cache/
*.mo
*.pot

# PT-BR: Relatórios e artefatos do mypy (checagem de tipos estática)
# EN: mypy (static type checking) reports and artifacts
.mypy_cache/
.dmypy.json
dmypy.json

# PT-BR: Artefatos do Ruff (linter)
# EN: Ruff (linter) artifacts
.ruff_cache/


# =============================================================================
# PT-BR: Jupyter Notebooks (se usados para análise/desenvolvimento)
# EN: Jupyter Notebooks (if used for analysis/development)
# =============================================================================
.ipynb_checkpoints
*.ipynb


# =============================================================================
# PT-BR: Arquivos Temporários e Uploads de Teste
# EN: Temporary Files and Test Uploads
# =============================================================================
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej

# PT-BR: Imagens de teste que possam ter sido carregadas durante desenvolvimento
# EN: Test images that may have been uploaded during development
test_uploads/
uploads/