# =============================================================================
# OCI DocGen — Environment Variables
# Copy this file to .env and fill in the values before running docker compose.
# =============================================================================

# -----------------------------------------------------------------------------
# Security (REQUIRED)
# -----------------------------------------------------------------------------
# Random string used to derive the Fernet encryption key for stored credentials.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Public URL of the frontend — used for CORS allow-list in the API.
FRONTEND_URL=http://localhost:5500

# Host port to expose the frontend on.
FRONTEND_PORT=5500

# -----------------------------------------------------------------------------
# OCI Default Authentication (optional — only needed without Tenancy Profiles)
# Set OCI_AUTH_METHOD=INSTANCE_PRINCIPAL when running inside OCI.
# Leave unset (defaults to API_KEY via ~/.oci/config) for local development.
# -----------------------------------------------------------------------------
# OCI_AUTH_METHOD=INSTANCE_PRINCIPAL
